/* ====== 全局样式 - 牌记 ====== */

page {
  --color-primary: #1A6B4A;
  --color-primary-light: #2E8B63;
  --color-accent: #D4A72C;
  --color-bg: #FAFAF5;
  --color-card: #FFFFFF;
  --color-text: #2D2D2D;
  --color-text-secondary: #888888;
  --color-border: #E8E8E0;
  --color-success: #22C55E;
  --color-danger: #EF4444;
  --color-shadow: rgba(0,0,0,0.06);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background-color: var(--color-bg);
  color: var(--color-text);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 深色模式变量覆盖 */
page.dark {
  --color-primary: #00D09C;
  --color-primary-light: #00B386;
  --color-accent: #FFD700;
  --color-bg: #1A1A2E;
  --color-card: #252540;
  --color-text: #E8E8E8;
  --color-text-secondary: #8888AA;
  --color-border: #353555;
  --color-success: #00D09C;
  --color-danger: #FF6B6B;
  --color-shadow: rgba(0,0,0,0.3);
}

/* 通用容器 */
.container {
  padding: var(--spacing-lg);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片基础样式 */
.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-lg);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-outline::after {
  border: none;
}

.btn-gold {
  background: linear-gradient(135deg, #D4A72C 0%, #F0C040 100%);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-gold::after {
  border: none;
}

/* 文字样式 */
.text-primary {
  color: var(--color-primary);
}

.text-accent {
  color: var(--color-accent);
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-success {
  color: var(--color-success);
}

.text-danger {
  color: var(--color-danger);
}

.text-bold {
  font-weight: 600;
}

.text-center {
  text-align: center;
}

/* 数字字体 */
.num {
  font-family: 'DIN Alternate', 'DIN Pro', -apple-system, 'Helvetica Neue', sans-serif;
  font-weight: 700;
  letter-spacing: 1rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-playing {
  background: rgba(26, 107, 74, 0.1);
  color: var(--color-primary);
}

.tag-settled {
  background: rgba(136, 136, 136, 0.1);
  color: var(--color-text-secondary);
}

/* flex */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--spacing-md) 0;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-border);
  overflow: hidden;
}

.avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-border);
  overflow: hidden;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-border);
  overflow: hidden;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  color: var(--color-text-secondary);
}

.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state .empty-text {
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.empty-state .empty-hint {
  font-size: 24rpx;
  opacity: 0.7;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin: 0 8rpx;
  animation: loadingBounce 1.4s ease-in-out infinite both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes loadingBounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}
