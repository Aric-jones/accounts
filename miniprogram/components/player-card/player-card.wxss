.player-card {
  background: var(--color-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}

.player-card.leading {
  border: 2rpx solid #D4A72C;
}

.leading-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  font-size: 28rpx;
}

.p-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.p-avatar image {
  width: 100%;
  height: 100%;
}

.p-avatar text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.p-name {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888);
  margin-bottom: 4rpx;
}

.p-score {
  font-size: 44rpx;
  font-weight: 800;
}

.p-score.positive { color: #22C55E; }
.p-score.negative { color: #EF4444; }
