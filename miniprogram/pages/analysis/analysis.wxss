/* AI分析页样式 */
.container {
  padding: 0 0 120rpx 0;
  min-height: 100vh;
  background: var(--color-bg);
}

/* AI Hero */
.ai-hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #2E8B63 100%);
  color: #FFFFFF;
}

.ai-avatar {
  font-size: 56rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-greeting {
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.95;
}

/* 通用卡片 */
.card {
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.share-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  padding: 8rpx 20rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: 24rpx;
}

/* 手气指数 */
.luck-ring-area {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.luck-ring {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.luck-canvas {
  width: 300rpx;
  height: 300rpx;
}

.luck-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.luck-score {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.luck-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.luck-comment {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  display: block;
}

/* 走势图 */
.trend-chart-area {
  position: relative;
  height: 200rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-end;
  padding-bottom: 40rpx;
}

.trend-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  width: 100%;
  height: 100%;
  position: relative;
}

.trend-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.trend-bar {
  width: 32rpx;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  transition: height 0.5s ease;
}

.trend-bar.positive {
  background: linear-gradient(180deg, var(--color-success) 0%, rgba(34, 197, 94, 0.4) 100%);
}

.trend-bar.negative {
  background: linear-gradient(180deg, rgba(239, 68, 68, 0.4) 0%, var(--color-danger) 100%);
  border-radius: 0 0 8rpx 8rpx;
}

.trend-label {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  position: absolute;
  bottom: 0;
}

.trend-zero-line {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 40rpx;
  height: 2rpx;
  background: var(--color-border);
}

.trend-stats {
  display: flex;
  justify-content: space-around;
}

.trend-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.trend-stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.trend-stat-value.positive { color: var(--color-success); }
.trend-stat-value.negative { color: var(--color-danger); }

.trend-stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 玩家风格 */
.style-tag-area {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.style-main-tag {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, rgba(26, 107, 74, 0.1) 0%, rgba(26, 107, 74, 0.03) 100%);
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(26, 107, 74, 0.2);
}

.style-tag-icon {
  font-size: 40rpx;
}

.style-tag-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.style-dimensions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dim-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dim-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  width: 60rpx;
  flex-shrink: 0;
}

.dim-bar-bg {
  flex: 1;
  height: 16rpx;
  background: var(--color-bg);
  border-radius: 8rpx;
  overflow: hidden;
}

.dim-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary) 0%, #2E8B63 100%);
  border-radius: 8rpx;
  transition: width 0.8s ease;
}

.dim-value {
  font-size: 24rpx;
  color: var(--color-text);
  font-weight: 600;
  width: 48rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 最佳搭档 */
.partner-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.partner-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.partner-rank {
  width: 40rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-accent);
  text-align: center;
}

.partner-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.partner-avatar text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.partner-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.partner-games {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.partner-rate {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
}

/* 运势预测 */
.fortune-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.fortune-stars {
  font-size: 40rpx;
}

.fortune-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.fortune-tip {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
}

/* 解锁区域 */
.unlock-area {
  padding: 0 32rpx;
  margin-top: 16rpx;
}

.btn-unlock {
  width: 100%;
}

.bottom-safe {
  height: 40rpx;
}
