<scroll-view scroll-y class="page-scroll {{theme === 'dark' ? 'dark' : ''}}">
  <!-- 标题 -->
  <view class="page-title">
    <text class="title-text">开一桌</text>
    <text class="title-desc">选好玩法，扫码邀请朋友加入</text>
  </view>

  <!-- 牌局名称 -->
  <view class="card">
    <text class="card-label">牌局名称</text>
    <input class="input-field" placeholder="例如：周六掼蛋局" value="{{roomName}}" bindinput="onNameInput" maxlength="20" />
  </view>

  <!-- 选择玩法 -->
  <view class="card">
    <text class="card-label">选择玩法</text>
    <view class="game-grid">
      <view class="game-item {{selectedGame === item.key ? 'active' : ''}}"
            wx:for="{{gameTypes}}" wx:key="key"
            bindtap="onSelectGame" data-key="{{item.key}}" hover-class="game-hover">
        <text class="game-icon">{{item.icon}}</text>
        <text class="game-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 每分金额 -->
  <view class="card">
    <view class="row-between">
      <text class="card-label" style="margin-bottom:0">每分金额</text>
      <view class="amount-wrap">
        <text class="amount-unit">¥</text>
        <input class="amount-input" type="digit" value="{{unitPrice}}" bindinput="onUnitPriceInput" placeholder="1" />
      </view>
    </view>
    <text class="hint-text">设为 0 则只记分不记钱</text>
  </view>

  <!-- 茶水费 -->
  <view class="card">
    <view class="row-between">
      <text class="card-label" style="margin-bottom:0">茶水费</text>
      <view class="amount-wrap">
        <input class="amount-input" type="number" value="{{teaFee}}" bindinput="onTeaFeeInput" placeholder="0" />
        <text class="amount-unit">分/人/局</text>
      </view>
    </view>
    <text class="hint-text">每局每人扣除的固定费用，设为 0 则不收</text>
  </view>

  <!-- 开桌按钮 -->
  <view class="btn-area">
    <button class="btn-primary" bindtap="onCreateRoom" loading="{{creating}}">
      🀄 立即开桌
    </button>
    <text class="btn-hint">开桌后分享房间码邀请牌友加入</text>
  </view>

  <!-- 底部广告区域 -->
  <view class="ad-zone">
    <view class="ad-zone-label">— 广告 —</view>
    <view class="ad-mock-banner">
      <view class="ad-mock-badge">广告</view>
      <view class="ad-mock-body">
        <view class="ad-mock-icon"></view>
        <view class="ad-mock-text">
          <text class="ad-mock-title">品牌推广</text>
          <text class="ad-mock-desc">Banner广告位 · 开桌页</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
