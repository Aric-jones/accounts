.page-scroll {
  height: 100vh;
  background: var(--color-bg);
}

.page-title {
  padding: 32rpx 32rpx 16rpx;
}

.title-text {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.title-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 8rpx;
}

.card {
  background: var(--color-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 16rpx 32rpx;
  box-shadow: 0 2rpx 12rpx var(--color-shadow);
}

.card-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 20rpx;
}

.input-field {
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
}

.game-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.game-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
}

.game-item.active {
  border-color: var(--color-primary);
  background: rgba(26, 107, 74, 0.06);
}

.game-hover {
  opacity: 0.7;
}

.game-icon {
  font-size: 44rpx;
  margin-bottom: 6rpx;
}

.game-name {
  font-size: 24rpx;
  color: var(--color-text);
}

.game-item.active .game-name {
  color: var(--color-primary);
  font-weight: 600;
}

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.amount-wrap {
  display: flex;
  align-items: center;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 8rpx 20rpx;
}

.amount-unit {
  font-size: 28rpx;
  color: var(--color-accent);
  font-weight: 600;
  margin-right: 8rpx;
}

.amount-input {
  width: 100rpx;
  font-size: 30rpx;
  color: var(--color-text);
  text-align: center;
}

.hint-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 12rpx;
}

.btn-area {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 20rpx;
  padding: 26rpx 0;
  font-size: 34rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.btn-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 16rpx;
}

.bottom-spacer {
  height: 40vh;
}
