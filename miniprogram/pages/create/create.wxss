/* 创建房间页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: var(--color-bg);
}

.card {
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.input-field {
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
}

/* 游戏类型网格 */
.game-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.game-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  transition: all 0.3s ease;
}

.game-item.active {
  border-color: var(--color-primary);
  background: rgba(26, 107, 74, 0.08);
  box-shadow: 0 0 0 2rpx var(--color-primary);
}

.game-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.game-name {
  font-size: 24rpx;
  color: var(--color-text);
  font-weight: 500;
}

.game-item.active .game-name {
  color: var(--color-primary);
  font-weight: 600;
}

/* 人数步进器 */
.player-count-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: var(--color-text);
}

.stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stepper-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.stepper-btn.disabled {
  opacity: 0.3;
  color: var(--color-text-secondary);
}

.stepper-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  min-width: 48rpx;
  text-align: center;
}

/* 玩家列表 */
.player-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.player-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.player-color {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.player-color text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.player-name-input {
  flex: 1;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

/* 计分设置 */
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
}

.amount-prefix {
  font-size: 28rpx;
  color: var(--color-accent);
  font-weight: 600;
  margin-right: 8rpx;
}

.amount-input {
  width: 120rpx;
  font-size: 32rpx;
  color: var(--color-text);
  text-align: center;
}

.setting-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
}

/* 创建按钮 */
.btn-area {
  padding: 32rpx 0;
}

.btn-create {
  height: 96rpx;
  font-size: 34rpx;
}
