/* 历史记录页样式 */
.container {
  padding: 0 0 120rpx 0;
  min-height: 100vh;
  background: var(--color-bg);
}

/* 统计摘要 */
.stats-summary {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 40rpx 32rpx;
  background: var(--color-card);
  margin-bottom: 2rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-text);
}

.stat-value.positive { color: var(--color-success); }
.stat-value.negative { color: var(--color-danger); }

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--color-border);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--color-card);
  overflow-x: auto;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.filter-item.active {
  background: var(--color-primary);
  color: #FFFFFF;
  font-weight: 600;
}

/* 历史列表 */
.history-list {
  padding: 0 32rpx;
}

.history-card {
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
  transition: transform 0.2s ease;
}

.history-card:active {
  transform: scale(0.98);
}

.history-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.history-icon {
  font-size: 32rpx;
}

.history-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.history-date {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.history-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-players {
  display: flex;
  gap: 24rpx;
}

.h-player {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.h-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.h-avatar text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.h-score {
  font-size: 26rpx;
  font-weight: 700;
}

.h-score.positive { color: var(--color-success); }
.h-score.negative { color: var(--color-danger); }

.history-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-rounds {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.history-winner {
  font-size: 22rpx;
  color: var(--color-accent);
  font-weight: 600;
}
