<scroll-view scroll-y class="page-scroll {{theme === 'dark' ? 'dark' : ''}}">
  <!-- 顶部欢迎区域 -->
  <view class="header">
    <view class="welcome-row">
      <view class="welcome-info">
        <text class="welcome-text">今晚来一局？</text>
        <text class="welcome-sub">记录每一局的精彩</text>
      </view>
      <view class="avatar-wrap" bindtap="onTapAvatar">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill" class="user-avatar-img" />
        <view wx:else class="user-avatar-placeholder">
          <text>{{userInfo.nickName ? userInfo.nickName[0] : '👤'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心操作按钮 -->
  <view class="action-area">
    <view class="btn-create" bindtap="onCreateRoom" hover-class="btn-hover">
      <text class="btn-icon">🀄</text>
      <text class="btn-text">开一桌</text>
      <text class="btn-desc">创建牌局，扫码邀请</text>
    </view>
    <view class="btn-join" bindtap="onJoinRoom" hover-class="btn-hover">
      <text class="btn-icon">🎯</text>
      <text class="btn-text">加入牌局</text>
      <text class="btn-desc">输入房间码加入</text>
    </view>
  </view>

  <!-- 进行中的牌局 -->
  <view class="section" wx:if="{{activeRooms.length > 0}}">
    <view class="section-header">
      <text class="section-title">进行中</text>
      <view class="section-badge">{{activeRooms.length}}</view>
    </view>
    <view class="room-card active-room" wx:for="{{activeRooms}}" wx:key="_id" bindtap="onEnterRoom" data-room="{{item}}" hover-class="card-hover">
      <view class="room-card-top">
        <view class="room-name-row">
          <text class="room-game-icon">{{item.gameIcon}}</text>
          <text class="room-name">{{item.name}}</text>
        </view>
        <view class="tag tag-playing">进行中</view>
      </view>
      <view class="room-card-body">
        <text class="room-meta-text">{{item.players.length}}人 · {{item.txnCount}}笔</text>
        <text class="room-time">{{item.timeAgo}}</text>
      </view>
    </view>
  </view>

  <!-- 底部广告区域 -->
  <view class="ad-zone">
    <view class="ad-zone-label">— 广告 —</view>
    <view class="ad-mock-banner">
      <view class="ad-mock-badge">广告</view>
      <view class="ad-mock-body">
        <view class="ad-mock-icon"></view>
        <view class="ad-mock-text">
          <text class="ad-mock-title">品牌推广</text>
          <text class="ad-mock-desc">Banner广告位 · 首页</text>
        </view>
      </view>
    </view>
    <view class="ad-mock-native">
      <view class="ad-mock-badge">广告</view>
      <view class="ad-mock-native-body">
        <view class="ad-mock-native-img"></view>
        <view class="ad-mock-native-info">
          <text class="ad-mock-title">精选推荐内容</text>
          <text class="ad-mock-desc">原生信息流广告位</text>
        </view>
      </view>
    </view>
    <view class="ad-mock-reward">
      <text class="ad-mock-reward-icon">🎁</text>
      <text class="ad-mock-reward-text">看视频领取牌运加成</text>
      <view class="ad-mock-reward-btn">观看</view>
    </view>
  </view>
</scroll-view>
