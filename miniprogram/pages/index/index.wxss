/* 首页样式 */
.container {
  padding: 0 0 180rpx 0;
  background: var(--color-bg);
  min-height: 100vh;
}

/* 顶部区域 */
.header {
  position: relative;
  padding: 0 32rpx;
  padding-top: 32rpx;
  margin-bottom: 32rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, transparent 100%);
  opacity: 0.08;
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.welcome-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.welcome-text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.welcome-sub {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  display: block;
}

.user-avatar,
.user-avatar-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  overflow: hidden;
  border: 4rpx solid var(--color-card);
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
}

/* 操作按钮区域 */
.action-area {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.btn-create {
  flex: 1;
  background: linear-gradient(135deg, var(--color-primary) 0%, #2E8B63 100%);
  color: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 107, 74, 0.3);
  transition: all 0.3s ease;
}

.btn-create:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(26, 107, 74, 0.2);
}

.btn-join {
  flex: 1;
  background: var(--color-card);
  color: var(--color-primary);
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
  border: 2rpx solid var(--color-border);
  transition: all 0.3s ease;
}

.btn-join:active {
  transform: scale(0.97);
}

.btn-icon {
  font-size: 56rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* 区域标题 */
.section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}

.section-badge {
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  font-weight: 600;
}

.section-more {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 房间卡片 */
.room-card {
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
  transition: all 0.3s ease;
}

.room-card:active {
  transform: scale(0.98);
}

.active-room {
  border-left: 8rpx solid var(--color-primary);
}

.room-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.room-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.room-game-icon {
  font-size: 36rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.room-card-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.room-players {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.player-avatar-stack {
  display: flex;
  align-items: center;
}

.stack-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid var(--color-card);
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.stack-avatar image {
  width: 100%;
  height: 100%;
}

.stack-avatar text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.stack-avatar.more {
  background: var(--color-border);
}

.room-player-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.room-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-rounds {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.room-winner {
  font-size: 24rpx;
  font-weight: 600;
}

.room-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.bottom-safe {
  height: 40rpx;
}
