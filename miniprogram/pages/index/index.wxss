.page-scroll {
  min-height: 100vh;
  height: 100vh;
  background: var(--color-bg);
}

/* 顶部区域 */
.header {
  padding: 32rpx 32rpx 0;
}

.welcome-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 32rpx;
}

.welcome-text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.welcome-sub {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  display: block;
}

.user-avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.user-avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* 操作按钮区域 */
.action-area {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.btn-create {
  flex: 1;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 107, 74, 0.3);
}

.btn-join {
  flex: 1;
  background: var(--color-card);
  color: var(--color-primary);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
  border: 2rpx solid var(--color-border);
}

.btn-hover {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-icon {
  font-size: 52rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

.btn-desc {
  font-size: 22rpx;
  opacity: 0.7;
}

/* 区域 */
.section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.section-badge {
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 2rpx 14rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
  font-weight: 600;
}

.section-more {
  font-size: 26rpx;
  color: var(--color-primary);
}

/* 房间卡片 */
.room-card {
  background: var(--color-card);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx var(--color-shadow);
}

.card-hover {
  opacity: 0.85;
}

.active-room {
  border-left: 6rpx solid var(--color-primary);
}

.room-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.room-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.room-game-icon {
  font-size: 32rpx;
}

.room-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-playing {
  background: rgba(26, 107, 74, 0.1);
  color: var(--color-primary);
}

.tag-settled {
  background: rgba(136, 136, 136, 0.1);
  color: var(--color-text-secondary);
}

.room-card-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-meta-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.room-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.room-winner {
  font-size: 24rpx;
  color: var(--color-accent);
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  color: var(--color-text-secondary);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  opacity: 0.6;
}

/* 底部留白 40% 屏幕高度 */
.bottom-spacer {
  height: 40vh;
}

/* 查看全部 */
.section-more-link {
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: var(--color-primary);
}
