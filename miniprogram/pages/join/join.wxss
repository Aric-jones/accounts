/* 加入房间页样式 */
.container {
  padding: 80rpx 48rpx;
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.join-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.join-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.join-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.join-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* 验证码输入框 */
.code-input-area {
  position: relative;
  margin-bottom: 64rpx;
  width: 100%;
}

.code-boxes {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.code-box {
  width: 88rpx;
  height: 104rpx;
  border-radius: 16rpx;
  border: 3rpx solid var(--color-border);
  background: var(--color-card);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.code-box.filled {
  border-color: var(--color-primary);
  background: rgba(26, 107, 74, 0.05);
}

.code-char {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.cover-input {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  z-index: 10;
}

/* 按钮 */
.btn-join {
  width: 100%;
  margin-bottom: 48rpx;
}

.btn-join[disabled] {
  opacity: 0.5;
}

.divider-text {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 48rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}

.divider-text text {
  margin: 0 24rpx;
}

.btn-scan {
  width: 100%;
}
