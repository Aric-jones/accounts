<scroll-view scroll-y class="page-scroll {{theme === 'dark' ? 'dark' : ''}}">
  <view class="room-content" wx:if="{{room}}">

    <!-- 顶部房间信息 -->
    <view class="room-header">
      <view class="room-header-left">
        <text class="room-title">{{room.name}}</text>
        <text class="room-meta">{{room.gameTypeName}} · ¥{{room.unitPrice}}/分</text>
      </view>
      <view class="header-right">
        <view class="share-code-box" bindtap="onCopyCode">
          <text class="code-label">房间码</text>
          <text class="code-value">{{room.shareCode}}</text>
        </view>
      </view>
    </view>

    <!-- 操作栏 -->
    <view class="action-bar">
      <view class="action-left">
        <view class="invite-toggle" bindtap="onToggleInvite" hover-class="btn-hover">{{showInvite ? '收起邀请' : '邀请玩家'}}</view>
        <view class="add-player-btn" bindtap="onAddPlayer" hover-class="btn-hover">+ 添加</view>
      </view>
      <view class="action-right">
        <view class="chart-btn" bindtap="onShowChart" wx:if="{{room.transactions.length > 0}}" hover-class="btn-hover">📈走势</view>
        <view class="undo-btn" bindtap="onUndo" wx:if="{{room.transactions.length > 0}}" hover-class="btn-hover">撤销</view>
        <view class="settle-btn" bindtap="onEndGame" hover-class="btn-hover">结算</view>
      </view>
    </view>

    <!-- 邀请区域 -->
    <view class="invite-area" wx:if="{{showInvite}}">
      <view class="invite-card">
        <view class="big-code-box">
          <text class="big-code-char" wx:for="{{codeChars}}" wx:key="index">{{item}}</text>
        </view>
        <text class="big-code-hint">让牌友输入房间码或扫码加入</text>
        <view class="invite-btns">
          <button class="btn-share-wx" open-type="share">转发</button>
          <button class="btn-copy-code" bindtap="onCopyCode">复制</button>
        </view>
      </view>
    </view>

    <!-- 玩家列表（横排紧凑） -->
    <view class="players-section">
      <text class="section-hint">点击玩家=支付 · 点茶=设置抽水 · <text class="edit-link" bindtap="onEditMyProfile">编辑资料</text></text>
      <scroll-view scroll-x class="players-scroll">
        <view class="player-chips">
          <!-- 茶水费（就是一个玩家） -->
          <view class="player-chip tea-chip" bindtap="onTapTeaFee" hover-class="chip-hover" wx:if="{{teaPlayer}}">
            <view class="chip-avatar-wrap">
              <view class="chip-avatar tea-avatar">
                <text>🍵</text>
              </view>
              <text class="tea-pending-badge" wx:if="{{pendingTeaFee > 0}}">{{pendingTeaFee}}</text>
            </view>
            <text class="chip-name">{{teaFeePercent}}%</text>
            <text class="chip-score {{teaFeeCollected > 0 ? 'win' : ''}}">
              {{teaFeeCollected > 0 ? '+' : ''}}{{teaFeeCollected}}
            </text>
          </view>

          <!-- 真实玩家 -->
          <view class="player-chip {{item.id === myPlayerId ? 'is-me' : ''}}" wx:for="{{realPlayers}}" wx:key="id"
                bindtap="onTapPlayer" data-id="{{item.id}}" hover-class="chip-hover">
            <view class="chip-avatar-wrap">
              <view class="chip-avatar" style="background:{{item.color}}">
                <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="chip-avatar-img" />
                <text wx:else>{{item.nickname[0]}}</text>
              </view>
              <text class="me-badge" wx:if="{{item.id === myPlayerId}}">我</text>
            </view>
            <text class="chip-name">{{item.nickname}}</text>
            <text class="chip-score {{item.totalScore > 0 ? 'win' : item.totalScore < 0 ? 'lose' : ''}}">
              {{item.totalScore > 0 ? '+' : ''}}{{item.totalScore}}
            </text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 最近交易记录 -->
    <view class="txn-section" wx:if="{{room.transactions.length > 0}}">
      <text class="section-title">交易记录 ({{room.transactions.length}}笔)</text>
      <view class="txn-list">
        <view class="txn-item {{item.to === '__tea__' ? 'txn-tea-row' : ''}}" wx:for="{{displayTxns}}" wx:key="index">
          <view class="txn-left">
            <text class="{{item.to === '__tea__' ? 'txn-tea-from' : 'txn-from'}}">{{item.fromName}}</text>
            <text class="txn-arrow">→</text>
            <text class="{{item.to === '__tea__' ? 'txn-tea-to' : 'txn-to'}}">{{item.toName}}</text>
          </view>
          <text class="txn-amount">{{item.amount}}分</text>
          <text class="txn-time">{{item.timeStr}}</text>
        </view>
      </view>
      <view class="txn-more" wx:if="{{room.transactions.length > 10}}" bindtap="onShowAllTxns">
        <text>{{showAllTxns ? '收起' : '查看全部 ' + room.transactions.length + ' 笔'}}</text>
      </view>
    </view>

    <!-- ========== 底部40%广告区域 ========== -->
    <view class="ad-zone">
      <view class="ad-zone-label">— 广告 —</view>

      <!-- Banner广告 -->
      <view class="ad-banner">
        <view class="ad-badge">广告</view>
        <view class="ad-body">
          <view class="ad-icon-placeholder"></view>
          <view class="ad-text-area">
            <text class="ad-title-text">某某品牌推广</text>
            <text class="ad-desc-text">Banner广告位 · 点击了解详情</text>
          </view>
        </view>
      </view>

      <!-- 原生信息流广告 -->
      <view class="ad-native">
        <view class="ad-badge">广告</view>
        <view class="ad-native-body">
          <view class="ad-native-img"></view>
          <view class="ad-native-info">
            <text class="ad-native-title">精选推荐内容</text>
            <text class="ad-native-desc">原生信息流广告位，上线后展示真实广告</text>
          </view>
        </view>
      </view>

      <!-- 激励视频入口 -->
      <view class="ad-reward">
        <view class="ad-badge">广告</view>
        <view class="ad-reward-content">
          <text class="ad-reward-icon">🎁</text>
          <text class="ad-reward-text">看视频领取牌运加成</text>
          <view class="ad-reward-btn">观看</view>
        </view>
      </view>
    </view>

  </view>

  <view class="loading-state" wx:if="{{!room}}">
    <text>加载中...</text>
  </view>
</scroll-view>

<!-- ========== 支付弹窗（居中） ========== -->
<view class="pay-mask" wx:if="{{showPayDialog}}" bindtap="onClosePayDialog"></view>
<view class="dialog-center {{showPayDialog ? 'show' : ''}}">
  <view class="panel-head">
    <text class="panel-title">支付给 {{payTarget.nickname}}</text>
    <view class="panel-close" bindtap="onClosePayDialog">✕</view>
  </view>

  <view class="payer-section">
    <text class="payer-label">谁在付款：</text>
    <view class="payer-chips">
      <view class="payer-chip {{payFrom.id === item.id ? 'active' : ''}} {{payTarget.id === item.id ? 'disabled' : ''}}"
            wx:for="{{realPlayers}}" wx:key="id"
            bindtap="onSwitchPayer" data-id="{{item.id}}">
        <view class="payer-dot" style="background:{{item.color}}"></view>
        <text>{{item.nickname}}</text>
      </view>
    </view>
  </view>

  <view class="quick-amounts">
    <view class="quick-btn {{payAmount === item ? 'active' : ''}}"
          wx:for="{{quickAmounts}}" wx:key="*this"
          bindtap="onQuickAmount" data-val="{{item}}" hover-class="btn-hover">
      {{item}}
    </view>
  </view>

  <view class="custom-row">
    <text class="custom-label">自定义</text>
    <input class="custom-input" type="number" placeholder="输入分数" maxlength="5"
           value="{{payAmount}}" bindinput="onPayAmountInput" focus="{{showPayDialog}}"
           adjust-position="{{false}}" bindfocus="onKeyboardShow" bindblur="onKeyboardHide" />
    <text class="custom-unit">分</text>
  </view>

  <button class="btn-primary btn-pay" bindtap="onConfirmPay" disabled="{{!payAmount || payAmount <= 0}}">
    {{payFrom.nickname}} 支付 {{payAmount || 0}} 分给 {{payTarget.nickname}}
  </button>
</view>

<!-- ========== 编辑资料弹窗 ========== -->
<view class="pay-mask" wx:if="{{showEditProfile}}" bindtap="onCloseEditProfile"></view>
<view class="dialog-center {{showEditProfile ? 'show' : ''}}">
  <view class="panel-head">
    <text class="panel-title">编辑资料</text>
    <view class="panel-close" bindtap="onCloseEditProfile">✕</view>
  </view>

  <!-- 头像 -->
  <view class="edit-avatar-section">
    <view class="edit-avatar-current" bindtap="onChooseAvatar"
          style="background:{{editPlayer.avatarColor || editPlayer.color}}">
      <image wx:if="{{editPlayer.avatarUrl}}" src="{{editPlayer.avatarUrl}}" mode="aspectFill" class="edit-avatar-img" />
      <text wx:else class="edit-avatar-letter">{{editPlayer.nickname[0]}}</text>
      <view class="edit-avatar-overlay">换</view>
    </view>
    <text class="edit-avatar-hint">点击更换头像</text>
  </view>

  <!-- 选择颜色 -->
  <view class="color-picker">
    <text class="color-label">头像底色</text>
    <view class="color-options">
      <view class="color-dot {{(editPlayer.avatarColor || editPlayer.color) === item ? 'active' : ''}}"
            style="background:{{item}}"
            wx:for="{{avatarColors}}" wx:key="*this"
            bindtap="onPickAvatarColor" data-color="{{item}}"></view>
    </view>
  </view>

  <!-- 昵称 -->
  <view class="edit-name-section">
    <text class="edit-label">昵称</text>
    <input class="input-field" value="{{editName}}" bindinput="onEditNameInput" maxlength="8" />
  </view>

  <button class="btn-primary btn-pay" bindtap="onSaveProfile">保存</button>
</view>

<!-- ========== 添加玩家弹窗 ========== -->
<view class="pay-mask" wx:if="{{showAddPlayer}}" bindtap="onCloseAddPlayer"></view>
<view class="dialog-center {{showAddPlayer ? 'show' : ''}}">
  <view class="panel-head">
    <text class="panel-title">添加玩家</text>
    <view class="panel-close" bindtap="onCloseAddPlayer">✕</view>
  </view>
  <view class="add-player-form">
    <input class="input-field" placeholder="输入玩家昵称" value="{{newPlayerName}}"
           bindinput="onNewPlayerInput" focus="{{showAddPlayer}}" />
  </view>
  <button class="btn-primary btn-pay" bindtap="onConfirmAddPlayer">添加</button>
</view>

<!-- ========== 茶水费设置弹窗 ========== -->
<view class="pay-mask" wx:if="{{showTeaPanel}}" bindtap="onCloseTeaPanel"></view>
<view class="pay-panel tea-panel {{showTeaPanel ? 'show' : ''}}">
  <view class="panel-head">
    <text class="panel-title">🍵 茶水费设置</text>
    <view class="panel-close" bindtap="onCloseTeaPanel">✕</view>
  </view>
  <view class="tea-setting-body">
    <view class="tea-percent-display">
      <text class="tea-percent-num">{{teaFeePercent}}%</text>
      <text class="tea-percent-hint">赢家收入抽水比例</text>
    </view>
    <view class="tea-rule-box">
      <text class="tea-rule" wx:if="{{teaFeePercent > 0}}">收取规则：每笔支付中，赢家获得的分数按{{teaFeePercent}}%扣除给茶水费。例如A付B 100分，茶水费={{100 * teaFeePercent / 100}}分，B实际得{{100 - 100 * teaFeePercent / 100}}分。</text>
      <text class="tea-rule" wx:if="{{teaFeePercent > 0}}">不收取：计算后茶水费不足1分（向下取整为0）时免收。</text>
      <text class="tea-rule" wx:if="{{teaFeePercent === 0}}">当前已关闭茶水费，设置比例后生效。</text>
    </view>
    <view class="tea-percent-bar">
      <view class="tea-pct-btn {{teaFeePercent === item ? 'active' : ''}}"
            wx:for="{{teaPercentOptions}}" wx:key="*this"
            data-val="{{item}}" bindtap="onPickTeaPercent">{{item}}%</view>
    </view>
    <view class="tea-collect-mode">
      <text class="tea-mode-label">收取方式</text>
      <view class="tea-mode-btns">
        <view class="tea-mode-btn {{teaCollectMode === 'immediate' ? 'active' : ''}}"
              data-mode="immediate" bindtap="onPickTeaMode">立即收取</view>
        <view class="tea-mode-btn {{teaCollectMode === 'manual' ? 'active' : ''}}"
              data-mode="manual" bindtap="onPickTeaMode">手动收取</view>
      </view>
      <text class="tea-mode-desc" wx:if="{{teaCollectMode === 'immediate'}}">每笔支付自动扣除赢家茶水费</text>
      <text class="tea-mode-desc" wx:if="{{teaCollectMode === 'manual'}}">一轮结束后点收取按钮，统一结算</text>
    </view>
    <view class="tea-stat-row">
      <view class="tea-stat-item">
        <text class="tea-stat-label">已收</text>
        <text class="tea-stat-val">{{teaFeeCollected}}分</text>
      </view>
      <view class="tea-stat-item pending" wx:if="{{teaCollectMode === 'manual'}}">
        <text class="tea-stat-label">待收</text>
        <text class="tea-stat-val">{{pendingTeaFee}}分</text>
      </view>
    </view>
  </view>
  <view class="tea-btn-row">
    <button class="btn-tea-save" bindtap="onSaveTeaSetting">保存设置</button>
    <button class="btn-tea-collect" wx:if="{{teaCollectMode === 'manual'}}" bindtap="onCollectTeaFee" disabled="{{pendingTeaFee <= 0}}">收取 {{pendingTeaFee}} 分</button>
  </view>
</view>

<!-- ========== 分数走势图弹窗 ========== -->
<view class="pay-mask" wx:if="{{showChart}}" bindtap="onCloseChart"></view>
<view class="chart-panel {{showChart ? 'show' : ''}}">
  <view class="panel-head">
    <text class="panel-title">📈 分数走势</text>
    <view class="panel-close" bindtap="onCloseChart">✕</view>
  </view>
  <view class="chart-legend">
    <view class="legend-item {{chartVisibleIds[item.id] ? 'active' : ''}}" wx:for="{{realPlayers}}" wx:key="id"
          bindtap="onToggleChartPlayer" data-id="{{item.id}}">
      <view class="legend-dot" style="background:{{item.color}}"></view>
      <text class="legend-name">{{item.nickname}}</text>
      <text class="legend-val {{item.totalScore > 0 ? 'win' : item.totalScore < 0 ? 'lose' : ''}}">{{item.totalScore > 0 ? '+' : ''}}{{item.totalScore}}</text>
    </view>
  </view>
  <view class="chart-canvas-wrap">
    <canvas type="2d" id="scoreChart" class="score-chart-canvas"
            bindtouchstart="onChartTouch" bindtouchmove="onChartTouch" bindtouchend="onChartTouchEnd"></canvas>
    <view class="chart-tooltip" wx:if="{{chartTooltip}}" style="left:{{chartTooltip.x}}px">
      <view class="tooltip-line"></view>
      <view class="tooltip-box {{chartTooltip.flipLeft ? 'flip-left' : ''}}">
        <text class="tooltip-title">#{{chartTooltip.idx}}</text>
        <view class="tooltip-row" wx:for="{{chartTooltip.items}}" wx:key="name">
          <view class="tooltip-dot" style="background:{{item.color}}"></view>
          <text class="tooltip-name">{{item.name}}</text>
          <text class="tooltip-val {{item.score > 0 ? 'win' : item.score < 0 ? 'lose' : ''}}">{{item.score > 0 ? '+' : ''}}{{item.score}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
