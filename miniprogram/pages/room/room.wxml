<scroll-view scroll-y class="page-scroll {{theme === 'dark' ? 'dark' : ''}}">
  <view class="room-content" wx:if="{{room}}">

    <!-- 顶部房间信息 -->
    <view class="room-header">
      <view class="room-header-left">
        <text class="room-title">{{room.name}}</text>
        <text class="room-meta">{{room.gameTypeName}} · 第 {{currentRound}} 局</text>
      </view>
      <view class="share-code-box" bindtap="onCopyCode">
        <text class="code-label">房间码</text>
        <text class="code-value">{{room.shareCode}}</text>
      </view>
    </view>

    <!-- 邀请区域 (没有开始记分时显示) -->
    <view class="invite-area" wx:if="{{room.players.length < 2 || showInvite}}">
      <view class="invite-card">
        <text class="invite-title">邀请牌友扫码加入</text>
        <text class="invite-desc">让牌友用微信「扫一扫」扫描下方二维码</text>

        <!-- 房间码大字展示 -->
        <view class="big-code-area">
          <view class="big-code-box">
            <text class="big-code-char" wx:for="{{codeChars}}" wx:key="index">{{item}}</text>
          </view>
          <text class="big-code-hint">或告诉牌友输入此房间码</text>
        </view>

        <!-- 操作按钮 -->
        <view class="invite-btns">
          <button class="btn-share-wx" open-type="share">
            转发给朋友
          </button>
          <button class="btn-copy-code" bindtap="onCopyCode">
            复制房间码
          </button>
        </view>
      </view>
    </view>

    <!-- 已加入的玩家列表 -->
    <view class="players-section">
      <view class="section-head">
        <text class="section-title">玩家 ({{room.players.length}}人)</text>
        <view class="add-player-btn" bindtap="onAddPlayer" hover-class="btn-hover">
          <text>+ 手动添加</text>
        </view>
      </view>

      <view class="player-grid">
        <view class="player-card" wx:for="{{room.players}}" wx:key="id">
          <view class="player-avatar" style="background:{{item.color}}">
            <image src="{{item.avatarUrl}}" mode="aspectFill" wx:if="{{item.avatarUrl}}"></image>
            <text wx:else class="avatar-letter">{{item.nickname[0]}}</text>
          </view>
          <text class="player-name">{{item.nickname}}</text>
          <view class="player-score-box">
            <text class="player-total num {{item.totalScore > 0 ? 'win' : item.totalScore < 0 ? 'lose' : ''}}">
              {{item.totalScore > 0 ? '+' : ''}}{{item.totalScore}}
            </text>
          </view>
          <view class="creator-badge" wx:if="{{item.isCreator}}">房主</view>
        </view>

        <!-- 空位：等待加入 -->
        <view class="player-card empty-slot" bindtap="onToggleInvite" wx:if="{{room.players.length < 8}}">
          <view class="empty-avatar">
            <text class="plus-icon">+</text>
          </view>
          <text class="empty-text">等待加入</text>
        </view>
      </view>
    </view>

    <!-- 对局记录 -->
    <view class="rounds-section" wx:if="{{room.rounds.length > 0}}">
      <text class="section-title">对局记录 ({{room.rounds.length}}局)</text>
      <scroll-view scroll-x class="rounds-scroll">
        <view class="rounds-row">
          <view class="round-col" wx:for="{{room.rounds}}" wx:key="roundNum">
            <text class="round-num">R{{item.roundNum}}</text>
            <view class="round-score" wx:for="{{room.players}}" wx:for-item="p" wx:key="id">
              <text class="rs-val num {{item.scores[p.id] > 0 ? 'win' : item.scores[p.id] < 0 ? 'lose' : ''}}">
                {{item.scores[p.id] || 0}}
              </text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 底部留白 -->
    <view class="bottom-spacer"></view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{!room}}">
    <text>加载中...</text>
  </view>
</scroll-view>

<!-- 底部操作栏（固定） -->
<view class="bottom-bar" wx:if="{{room}}">
  <view class="bar-btn" bindtap="onUndo" wx:if="{{room.rounds.length > 0}}" hover-class="btn-hover">
    <text>↩ 撤销</text>
  </view>
  <view class="bar-main-btn" bindtap="onOpenScoreInput" hover-class="btn-hover">
    <text>✏️ 记一局</text>
  </view>
  <view class="bar-btn" bindtap="onEndGame" hover-class="btn-hover">
    <text>🏁 结算</text>
  </view>
</view>

<!-- 记分弹窗 -->
<view class="score-mask" wx:if="{{showScoreInput}}" bindtap="onCloseScoreInput"></view>
<view class="score-panel {{showScoreInput ? 'show' : ''}}">
  <view class="panel-head">
    <text class="panel-title">记录第 {{currentRound + 1}} 局</text>
    <view class="panel-close" bindtap="onCloseScoreInput">✕</view>
  </view>
  <view class="score-rows">
    <view class="score-row" wx:for="{{room.players}}" wx:key="id" wx:if="{{room}}">
      <view class="sr-player">
        <view class="sr-color" style="background:{{item.color}}">
          <text>{{item.nickname[0]}}</text>
        </view>
        <text class="sr-name">{{item.nickname}}</text>
      </view>
      <view class="sr-input-area">
        <view class="sr-quick" bindtap="onQuickScore" data-id="{{item.id}}" data-delta="{{-10}}">-10</view>
        <input class="sr-input num" type="number" value="{{currentScores[item.id]}}"
               bindinput="onScoreInput" data-id="{{item.id}}" placeholder="0" />
        <view class="sr-quick plus" bindtap="onQuickScore" data-id="{{item.id}}" data-delta="{{10}}">+10</view>
      </view>
    </view>
  </view>
  <view class="score-sum">
    <text>总和: </text>
    <text class="num {{scoreSum === 0 ? 'balanced' : 'unbalanced'}}">{{scoreSum}}</text>
    <text class="sum-hint" wx:if="{{scoreSum !== 0}}"> (建议为0)</text>
  </view>
  <button class="btn-primary btn-submit" bindtap="onSubmitScore">✓ 确认记录</button>
</view>

<!-- 手动添加玩家弹窗 -->
<view class="score-mask" wx:if="{{showAddPlayer}}" bindtap="onCloseAddPlayer"></view>
<view class="score-panel {{showAddPlayer ? 'show' : ''}}">
  <view class="panel-head">
    <text class="panel-title">添加玩家</text>
    <view class="panel-close" bindtap="onCloseAddPlayer">✕</view>
  </view>
  <view class="add-player-form">
    <text class="card-label">昵称</text>
    <input class="input-field" placeholder="输入玩家昵称" value="{{newPlayerName}}" bindinput="onNewPlayerInput" focus="{{showAddPlayer}}" />
  </view>
  <button class="btn-primary btn-submit" bindtap="onConfirmAddPlayer">✓ 添加</button>
</view>
