.page-scroll {
  height: 100vh;
  background: var(--color-bg);
}

.room-content {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* === 顶部 === */
.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 24rpx;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
}

.room-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.room-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 2rpx;
}

.share-code-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-bg);
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  border: 1rpx dashed var(--color-border);
}

.code-label { font-size: 16rpx; color: var(--color-text-secondary); }

.code-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
  font-family: 'Courier New', monospace;
}

/* === 操作栏 === */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
}

.action-left, .action-right {
  display: flex;
  gap: 12rpx;
}

.invite-toggle, .add-player-btn {
  font-size: 22rpx;
  color: var(--color-primary);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: 20rpx;
}

.chart-btn {
  font-size: 22rpx;
  color: var(--color-primary);
  padding: 6rpx 16rpx;
  background: var(--color-bg);
  border-radius: 20rpx;
  border: 1rpx solid var(--color-primary);
}

.undo-btn {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  padding: 6rpx 16rpx;
  background: var(--color-bg);
  border-radius: 20rpx;
}

.settle-btn {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 16rpx;
  background: var(--color-primary);
  border-radius: 20rpx;
  font-weight: 600;
}

.btn-hover { opacity: 0.7; }

/* === 邀请 === */
.invite-area {
  padding: 12rpx 24rpx;
}

.invite-card {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx var(--color-shadow);
}

.big-code-box {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.big-code-char {
  width: 52rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  font-family: 'Courier New', monospace;
  border-radius: 8rpx;
  text-align: center;
}

.big-code-hint {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.invite-btns {
  display: flex;
  gap: 12rpx;
}

.invite-btns button {
  flex: 1;
  font-size: 22rpx;
  border-radius: 10rpx;
  padding: 12rpx 0;
  margin: 0;
  line-height: 1.5;
}

.invite-btns button::after { border: none; }
.btn-share-wx { background: #07C160; color: #fff; }

.btn-copy-code {
  background: var(--color-bg);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}

/* === 玩家列表（横排紧凑） === */
.players-section {
  padding: 12rpx 24rpx;
}

.section-hint {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 8rpx;
  text-align: center;
}

.players-scroll {
  white-space: nowrap;
  height: 180rpx;
}

.player-chips {
  display: inline-flex;
  gap: 24rpx;
  padding: 10rpx 4rpx 16rpx;
  align-items: flex-start;
}

.player-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}

.chip-hover { opacity: 0.7; }

.chip-avatar-wrap {
  position: relative;
  margin-bottom: 2rpx;
}

.chip-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  position: relative;
  overflow: hidden;
  border: 3rpx solid transparent;
  box-sizing: content-box;
}

.player-chip.is-me .chip-avatar {
  border-color: var(--color-primary);
}

.chip-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.chip-avatar text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
}

.me-badge {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  font-size: 14rpx;
  background: var(--color-primary);
  color: #fff;
  padding: 0 8rpx;
  border-radius: 6rpx;
  height: 22rpx;
  line-height: 22rpx;
  z-index: 2;
}

.chip-name {
  font-size: 20rpx;
  color: var(--color-text);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  height: 28rpx;
  line-height: 28rpx;
  display: block;
}

.chip-score {
  font-size: 24rpx;
  font-weight: 800;
  font-family: 'DIN Alternate', 'Courier New', monospace;
  color: var(--color-text);
  height: 32rpx;
  line-height: 32rpx;
  white-space: nowrap;
  text-align: center;
  display: block;
}

.chip-score.win { color: #22C55E; }
.chip-score.lose { color: #EF4444; }

.tea-stat {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  text-align: center;
  padding: 6rpx;
  background: rgba(212, 167, 44, 0.08);
  border-radius: 8rpx;
}

/* === 交易记录 === */
.txn-section {
  padding: 12rpx 24rpx;
}

.txn-list {
  background: var(--color-card);
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.txn-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
  font-size: 24rpx;
}

.txn-item:last-child { border-bottom: none; }

.txn-left {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.txn-from { color: #EF4444; font-weight: 600; }
.txn-arrow { color: var(--color-text-secondary); font-size: 20rpx; }
.txn-to { color: #22C55E; font-weight: 600; }

.txn-tea-row {
  background: rgba(107, 175, 141, 0.05);
}

.txn-tea-from { color: #6BAF8D; font-weight: 600; }
.txn-tea-to { color: #6BAF8D; font-weight: 600; }

.txn-table-row {
  background: rgba(245, 158, 11, 0.05);
}

.txn-table-name { color: #D97706; font-weight: 600; }

.txn-amount {
  font-weight: 700;
  color: var(--color-text);
  min-width: 70rpx;
  text-align: right;
  margin-left: 12rpx;
}

.txn-time {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  min-width: 70rpx;
  text-align: right;
}

.txn-more {
  text-align: center;
  padding: 12rpx;
  font-size: 22rpx;
  color: var(--color-primary);
}

/* ========== 底部40%广告区域 ========== */
.ad-zone {
  margin-top: auto;
  min-height: 40vh;
  padding: 24rpx;
  background: linear-gradient(to bottom, var(--color-bg) 0%, #f0f0f0 100%);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ad-zone-label {
  text-align: center;
  font-size: 20rpx;
  color: #bbb;
  margin-bottom: 4rpx;
}

.ad-banner {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  position: relative;
  border: 1rpx solid #e8e8e8;
}

.ad-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 16rpx;
  color: #999;
  background: #eee;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  line-height: 1.4;
}

.ad-body {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ad-icon-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #ddd 0%, #bbb 100%);
  flex-shrink: 0;
}

.ad-text-area { flex: 1; }

.ad-title-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  display: block;
}

.ad-desc-text {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.ad-native {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  position: relative;
  border: 1rpx solid #e8e8e8;
}

.ad-native-body {
  display: flex;
  gap: 16rpx;
}

.ad-native-img {
  width: 180rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #d4d4d4 0%, #aaa 100%);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.ad-native-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.ad-native-title {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  display: block;
}

.ad-native-desc {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.ad-reward {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEDD5 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  position: relative;
  border: 1rpx solid #F5D0A9;
}

.ad-reward-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ad-reward-icon { font-size: 36rpx; }

.ad-reward-text {
  flex: 1;
  font-size: 26rpx;
  color: #8B5E3C;
  font-weight: 600;
}

.ad-reward-btn {
  padding: 8rpx 24rpx;
  background: #FF8C00;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx;
  color: var(--color-text-secondary);
}

/* ========== 弹窗通用 ========== */
.pay-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.pay-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--color-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.15);
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.pay-panel.show { transform: translateY(0); }

/* 居中弹窗 */
.dialog-center {
  position: fixed;
  top: 38%;
  left: 50%;
  width: 88%;
  max-width: 640rpx;
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.25);
  z-index: 100;
  transform: translate(-50%, -50%) scale(0.8);
  opacity: 0;
  transition: transform 0.25s ease, opacity 0.25s ease;
  pointer-events: none;
}

.dialog-center.show {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
  pointer-events: auto;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* === 快捷金额 === */
.quick-amounts {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.quick-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.quick-btn.active {
  border-color: var(--color-primary);
  background: rgba(26, 107, 74, 0.1);
  color: var(--color-primary);
}

/* === 自定义金额 === */
.custom-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.custom-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  background: var(--color-bg);
  text-align: center;
}

.custom-unit {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 22rpx 0;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary::after { border: none; }

.btn-primary[disabled] {
  background: #ccc;
  color: #999;
}

/* === 付款人选择 === */
.payer-section {
  margin-bottom: 16rpx;
}

.payer-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 8rpx;
}

.payer-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.payer-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: var(--color-text);
}

.payer-chip.active {
  border-color: var(--color-primary);
  background: rgba(26, 107, 74, 0.1);
  color: var(--color-primary);
  font-weight: 600;
}

.payer-chip.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.payer-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

/* === 编辑资料面板 === */
.edit-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.edit-avatar-current {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
}

.edit-avatar-letter {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.edit-avatar-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 36rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-avatar-hint {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.color-picker {
  margin-bottom: 20rpx;
}

.color-label {
  font-size: 24rpx;
  color: var(--color-text);
  display: block;
  margin-bottom: 10rpx;
}

.color-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
}

.color-dot.active {
  border-color: var(--color-text);
  box-shadow: 0 0 0 3rpx #fff, 0 0 0 6rpx var(--color-text);
}

.edit-name-section {
  margin-bottom: 20rpx;
}

.edit-label {
  font-size: 24rpx;
  color: var(--color-text);
  display: block;
  margin-bottom: 8rpx;
}

/* === 添加玩家 === */
.add-player-form {
  margin-bottom: 20rpx;
}

.input-field {
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

/* === 茶水费/台面特殊样式已统一，不再需要单独样式 === */

/* === 茶水费设置面板 === */
.tea-panel {
  max-height: 75vh;
}

.tea-setting-body {
  padding: 10rpx 0 20rpx;
}

.tea-percent-display {
  text-align: center;
  margin-bottom: 24rpx;
}

.tea-percent-num {
  display: block;
  font-size: 56rpx;
  font-weight: 900;
  color: #6BAF8D;
  font-family: 'DIN Alternate', monospace;
}

.tea-percent-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.tea-rule-box {
  background: rgba(107,175,141,0.06);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin: 12rpx 0;
}

.tea-rule {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
}

.tea-percent-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  margin-bottom: 30rpx;
}

.tea-pct-btn {
  width: 90rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  color: var(--color-text);
}

.tea-pct-btn.active {
  background: #6BAF8D;
  color: #fff;
  border-color: #6BAF8D;
}

.tea-collect-mode {
  margin-bottom: 20rpx;
}

.tea-mode-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 10rpx;
}

.tea-mode-btns {
  display: flex;
  gap: 16rpx;
}

.tea-mode-btn {
  flex: 1;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  color: var(--color-text);
}

.tea-mode-btn.active {
  background: #6BAF8D;
  color: #fff;
  border-color: #6BAF8D;
}

.tea-mode-desc {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 8rpx;
}

.tea-stat-row {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 20rpx;
}

.tea-stat-item {
  text-align: center;
  padding: 12rpx 24rpx;
  background: rgba(107, 175, 141, 0.08);
  border-radius: 12rpx;
  min-width: 140rpx;
}

.tea-stat-item.pending {
  background: rgba(245, 158, 11, 0.08);
}

.tea-stat-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: block;
}

.tea-stat-val {
  font-size: 32rpx;
  font-weight: 800;
  color: #6BAF8D;
  font-family: 'DIN Alternate', monospace;
}

.tea-stat-item.pending .tea-stat-val {
  color: #F59E0B;
}

.tea-rule-hint {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.tea-btn-row {
  display: flex;
  gap: 16rpx;
}

.tea-btn-row button {
  flex: 1;
  margin: 0;
  font-size: 26rpx;
  border-radius: 14rpx;
  padding: 16rpx 0;
  line-height: 1.4;
}

.tea-btn-row button::after { border: none; }

.btn-tea-save {
  background: var(--color-bg) !important;
  color: var(--color-text) !important;
  border: 2rpx solid var(--color-border) !important;
}

.btn-tea-collect {
  background: #6BAF8D !important;
  color: #fff !important;
}

.btn-tea-collect[disabled] {
  opacity: 0.4;
}

.tea-pending-badge {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  font-size: 14rpx;
  color: #fff;
  background: #F59E0B;
  padding: 0 8rpx;
  border-radius: 6rpx;
  height: 22rpx;
  line-height: 22rpx;
  z-index: 2;
}

.edit-link {
  color: var(--color-primary);
  text-decoration: underline;
}

/* === 分数走势图面板 === */
.chart-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-card);
  border-radius: 28rpx 28rpx 0 0;
  padding: 24rpx 24rpx 48rpx;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  overflow-y: auto;
}

.chart-panel.show {
  transform: translateY(0);
}

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 12rpx 0 16rpx;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid var(--color-border);
  opacity: 0.45;
  transition: opacity 0.2s, border-color 0.2s;
}

.legend-item.active {
  opacity: 1;
  border-color: var(--color-primary);
  background: rgba(58,170,119,0.08);
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-name {
  font-size: 22rpx;
  color: var(--color-text);
}

.legend-val {
  font-size: 22rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', monospace;
  color: var(--color-text);
}

.legend-val.win { color: #22C55E; }
.legend-val.lose { color: #EF4444; }

.chart-canvas-wrap {
  width: 100%;
  height: 400rpx;
  position: relative;
}

.score-chart-canvas {
  width: 100%;
  height: 100%;
}

/* 走势图触摸提示 */
.chart-tooltip {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 0;
  pointer-events: none;
}

.tooltip-line {
  position: absolute;
  top: 0;
  bottom: 30rpx;
  left: 0;
  width: 1px;
  background: rgba(0,0,0,0.2);
  border-left: 1px dashed rgba(0,0,0,0.3);
}

.tooltip-box {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: auto;
  background: rgba(0,0,0,0.8);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  min-width: 180rpx;
  z-index: 10;
}

.tooltip-box.flip-left {
  left: auto;
  right: 10rpx;
}

.tooltip-title {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-bottom: 6rpx;
}

.tooltip-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.tooltip-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.tooltip-name {
  font-size: 20rpx;
  color: #fff;
  flex: 1;
}

.tooltip-val {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.tooltip-val.win { color: #4ADE80; }
.tooltip-val.lose { color: #F87171; }

/* 邀请海报弹窗 */
.qr-dialog {
  max-width: 580rpx;
}

.qr-poster {
  text-align: center;
  padding: 24rpx 0;
}

.qr-poster-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.qr-poster-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 28rpx;
}

.qr-code-display {
  display: flex;
  justify-content: center;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.qr-code-char {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  border-radius: 14rpx;
  font-family: 'DIN Alternate', monospace;
}

.qr-wxacode-img {
  width: 400rpx;
  height: 400rpx;
  margin: 20rpx auto;
  display: block;
  border-radius: 12rpx;
}

.qr-loading {
  width: 400rpx;
  height: 400rpx;
  margin: 20rpx auto;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.qr-poster-tip {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  text-align: center;
}

.qr-btn-row {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0 0;
}

.qr-share-btn, .qr-copy-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 0;
  margin: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
}

.qr-share-btn {
  background: var(--color-primary);
  color: #fff;
}

.qr-copy-btn {
  background: var(--color-bg);
  color: var(--color-text);
  border: 2rpx solid var(--color-border);
}

.voice-btn {
  font-size: 28rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  opacity: 0.5;
}

.voice-btn.active {
  opacity: 1;
}


.btn-qr-code {
  font-size: 24rpx;
  padding: 0;
  margin: 0;
  background: rgba(26,107,74,0.08);
  color: var(--color-primary);
  border-radius: 12rpx;
  height: 64rpx;
  line-height: 64rpx;
}

/* === 台面 (Table) === */


.table-help-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0 12rpx;
  font-size: 22rpx;
  color: var(--color-primary);
}

.table-help-icon {
  font-size: 24rpx;
}

.table-help-box {
  background: rgba(245,158,11,0.08);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.table-help-text {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.table-dir-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.table-dir-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border);
  background: var(--color-bg);
  font-size: 26rpx;
  color: var(--color-text);
  transition: all 0.2s;
}

.table-dir-btn.active {
  border-color: var(--color-primary);
  background: rgba(26,107,74,0.08);
  color: var(--color-primary);
  font-weight: 600;
}

.table-dir-desc {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  font-weight: 400;
}

.table-dir-btn.active .table-dir-desc {
  color: var(--color-primary);
  opacity: 0.7;
}

.table-balance-hint {
  text-align: center;
  font-size: 22rpx;
  color: #F59E0B;
  padding: 8rpx 0;
}

.btn-table-take {
  background: linear-gradient(135deg, #F59E0B, #D97706) !important;
}

.btn-table-pay {
  background: var(--color-primary) !important;
}
