.page-scroll {
  height: 100vh;
  background: var(--color-bg);
}

.room-content {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* === 顶部 === */
.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 24rpx;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
}

.room-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.room-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 2rpx;
}

.share-code-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-bg);
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  border: 1rpx dashed var(--color-border);
}

.code-label { font-size: 16rpx; color: var(--color-text-secondary); }

.code-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
  font-family: 'Courier New', monospace;
}

/* === 操作栏 === */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
}

.action-left, .action-right {
  display: flex;
  gap: 12rpx;
}

.invite-toggle, .add-player-btn {
  font-size: 22rpx;
  color: var(--color-primary);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: 20rpx;
}

.undo-btn {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  padding: 6rpx 16rpx;
  background: var(--color-bg);
  border-radius: 20rpx;
}

.settle-btn {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 16rpx;
  background: var(--color-primary);
  border-radius: 20rpx;
  font-weight: 600;
}

.btn-hover { opacity: 0.7; }

/* === 邀请 === */
.invite-area {
  padding: 12rpx 24rpx;
}

.invite-card {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx var(--color-shadow);
}

.big-code-box {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.big-code-char {
  width: 52rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  font-family: 'Courier New', monospace;
  border-radius: 8rpx;
  text-align: center;
}

.big-code-hint {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.invite-btns {
  display: flex;
  gap: 12rpx;
}

.invite-btns button {
  flex: 1;
  font-size: 22rpx;
  border-radius: 10rpx;
  padding: 12rpx 0;
  margin: 0;
  line-height: 1.4;
}

.invite-btns button::after { border: none; }
.btn-share-wx { background: #07C160; color: #fff; }

.btn-copy-code {
  background: var(--color-bg);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}

/* === 玩家列表 === */
.players-section {
  padding: 12rpx 24rpx;
}

.section-title {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 10rpx;
}

.player-list {
  background: var(--color-card);
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.player-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.player-row:last-child { border-bottom: none; }

.row-hover {
  background: rgba(26, 107, 74, 0.05);
}

.pr-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pr-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pr-avatar text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.pr-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.pr-name {
  font-size: 28rpx;
  color: var(--color-text);
}

.creator-tag {
  font-size: 16rpx;
  background: var(--color-accent, #D4A72C);
  color: #fff;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.pr-score {
  font-size: 36rpx;
  font-weight: 800;
  font-family: 'DIN Alternate', 'Courier New', monospace;
  color: var(--color-text);
}

.pr-score.win { color: #22C55E; }
.pr-score.lose { color: #EF4444; }

.tea-stat {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  text-align: center;
  padding: 6rpx;
  background: rgba(212, 167, 44, 0.08);
  border-radius: 8rpx;
}

/* === 交易记录 === */
.txn-section {
  padding: 12rpx 24rpx;
}

.txn-list {
  background: var(--color-card);
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.txn-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
  font-size: 24rpx;
}

.txn-item:last-child { border-bottom: none; }

.txn-left {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.txn-from { color: #EF4444; font-weight: 600; }
.txn-arrow { color: var(--color-text-secondary); font-size: 20rpx; }
.txn-to { color: #22C55E; font-weight: 600; }

.txn-amount {
  font-weight: 700;
  color: var(--color-text);
  margin: 0 12rpx;
  min-width: 80rpx;
  text-align: right;
}

.txn-time {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  min-width: 70rpx;
  text-align: right;
}

.txn-more {
  text-align: center;
  padding: 12rpx;
  font-size: 22rpx;
  color: var(--color-primary);
}

/* ========== 底部40%广告区域 ========== */
.ad-zone {
  margin-top: auto;
  min-height: 40vh;
  padding: 24rpx;
  background: linear-gradient(to bottom, var(--color-bg) 0%, #f0f0f0 100%);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ad-zone-label {
  text-align: center;
  font-size: 20rpx;
  color: #bbb;
  margin-bottom: 4rpx;
}

.ad-banner {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  position: relative;
  border: 1rpx solid #e8e8e8;
}

.ad-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 16rpx;
  color: #999;
  background: #eee;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  line-height: 1.4;
}

.ad-body {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ad-icon-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #ddd 0%, #bbb 100%);
  flex-shrink: 0;
}

.ad-text-area { flex: 1; }

.ad-title-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  display: block;
}

.ad-desc-text {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.ad-native {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  position: relative;
  border: 1rpx solid #e8e8e8;
}

.ad-native-body {
  display: flex;
  gap: 16rpx;
}

.ad-native-img {
  width: 180rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #d4d4d4 0%, #aaa 100%);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.ad-native-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.ad-native-title {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  display: block;
}

.ad-native-desc {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.ad-reward {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEDD5 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  position: relative;
  border: 1rpx solid #F5D0A9;
}

.ad-reward-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ad-reward-icon { font-size: 36rpx; }

.ad-reward-text {
  flex: 1;
  font-size: 26rpx;
  color: #8B5E3C;
  font-weight: 600;
}

.ad-reward-btn {
  padding: 8rpx 24rpx;
  background: #FF8C00;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx;
  color: var(--color-text-secondary);
}

/* ========== 弹窗通用 ========== */
.pay-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.pay-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--color-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.15);
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.pay-panel.show { transform: translateY(0); }

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* === 快捷金额 === */
.quick-amounts {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.quick-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.quick-btn.active {
  border-color: var(--color-primary);
  background: rgba(26, 107, 74, 0.1);
  color: var(--color-primary);
}

/* === 自定义金额 === */
.custom-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.custom-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  background: var(--color-bg);
  text-align: center;
}

.custom-unit {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 22rpx 0;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary::after { border: none; }

.btn-primary[disabled] {
  background: #ccc;
  color: #999;
}

/* === 添加玩家 === */
.add-player-form {
  margin-bottom: 20rpx;
}

.input-field {
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: var(--color-text);
}
