.page-scroll {
  height: 100vh;
  background: var(--color-bg);
}

.room-content {
  padding-bottom: 140rpx;
}

/* 顶部信息 */
.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
}

.room-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.room-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
}

.share-code-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-bg);
  padding: 10rpx 20rpx;
  border-radius: 14rpx;
  border: 2rpx dashed var(--color-border);
}

.code-label {
  font-size: 18rpx;
  color: var(--color-text-secondary);
}

.code-value {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 3rpx;
  font-family: 'Courier New', monospace;
}

/* 邀请区域 */
.invite-area {
  padding: 24rpx 32rpx;
}

.invite-card {
  background: var(--color-card);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx var(--color-shadow);
}

.invite-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.invite-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.big-code-area {
  margin-bottom: 32rpx;
}

.big-code-box {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.big-code-char {
  width: 72rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 800;
  font-family: 'Courier New', monospace;
  border-radius: 14rpx;
  text-align: center;
}

.big-code-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.invite-btns {
  display: flex;
  gap: 20rpx;
}

.invite-btns button {
  flex: 1;
  font-size: 26rpx;
  border-radius: 16rpx;
  padding: 18rpx 0;
  margin: 0;
}

.invite-btns button::after {
  border: none;
}

.btn-share-wx {
  background: #07C160;
  color: #FFFFFF;
}

.btn-copy-code {
  background: var(--color-bg);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

/* 玩家区域 */
.players-section {
  padding: 24rpx 32rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.add-player-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  padding: 8rpx 20rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: 24rpx;
}

.btn-hover {
  opacity: 0.7;
}

.player-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.player-card {
  background: var(--color-card);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 10rpx var(--color-shadow);
  position: relative;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.player-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-letter {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.player-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 4rpx;
}

.player-total {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-text);
}

.player-total.win {
  color: #22C55E;
}

.player-total.lose {
  color: #EF4444;
}

.creator-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
  background: var(--color-accent);
  color: #FFFFFF;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.empty-slot {
  border: 2rpx dashed var(--color-border);
  background: transparent;
  box-shadow: none;
}

.empty-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.plus-icon {
  font-size: 40rpx;
  color: var(--color-text-secondary);
}

.empty-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 对局记录 */
.rounds-section {
  padding: 24rpx 32rpx;
}

.rounds-scroll {
  margin-top: 16rpx;
  white-space: nowrap;
}

.rounds-row {
  display: inline-flex;
  gap: 12rpx;
}

.round-col {
  background: var(--color-card);
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  min-width: 100rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.round-num {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.rs-val {
  font-size: 24rpx;
  font-weight: 600;
}

.rs-val.win { color: #22C55E; }
.rs-val.lose { color: #EF4444; }

.bottom-spacer {
  height: 40vh;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx;
  color: var(--color-text-secondary);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-card);
  box-shadow: 0 -2rpx 16rpx var(--color-shadow);
  z-index: 50;
}

.bar-btn {
  padding: 14rpx 28rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
}

.bar-main-btn {
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #FFFFFF;
  padding: 18rpx 56rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(26, 107, 74, 0.3);
}

/* 弹窗 */
.score-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.score-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-card);
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.15);
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 75vh;
  overflow-y: auto;
}

.score-panel.show {
  transform: translateY(0);
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}

.panel-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.score-rows {
  margin-bottom: 20rpx;
}

.score-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.sr-player {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 140rpx;
}

.sr-color {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sr-color text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.sr-name {
  font-size: 26rpx;
  color: var(--color-text);
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sr-input-area {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sr-quick {
  width: 64rpx;
  height: 52rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(239, 68, 68, 0.08);
  color: #EF4444;
}

.sr-quick.plus {
  background: rgba(34, 197, 94, 0.08);
  color: #22C55E;
}

.sr-input {
  width: 120rpx;
  height: 52rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 10rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-text);
  background: var(--color-bg);
}

.score-sum {
  text-align: center;
  padding: 14rpx;
  background: var(--color-bg);
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.balanced { color: #22C55E; font-weight: 700; }
.unbalanced { color: #EF4444; font-weight: 700; }

.sum-hint {
  font-size: 22rpx;
  color: #EF4444;
}

.btn-submit {
  margin-top: 8rpx;
}

/* 添加玩家表单 */
.add-player-form {
  margin-bottom: 24rpx;
}

.card-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 16rpx;
}

.input-field {
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #1A6B4A 0%, #2E8B63 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}
